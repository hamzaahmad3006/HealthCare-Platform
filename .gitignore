node_modules/
**/node_modules/
.pnp
.pnp.js
jspm_packages/

# ─────────────────────────────────────────────────────────────────────────────
# Environment & secrets — NEVER COMMIT
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
