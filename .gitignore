# ─────────────────────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.vite/
**/dist/
**/build/

# TypeScript build cache
*.tsbuildinfo
.tscache/

# ─────────────────────────────────────────────────────────────────────────────
# Prisma — never commit generated client or local migrations to be ignored
# (Keep migrations checked in — they're source of truth)
# ─────────────────────────────────────────────────────────────────────────────
healthcare-backend/prisma/migrations/dev.db
healthcare-backend/prisma/dev.db
healthcare-backend/prisma/*.sqlite
healthcare-backend/prisma/*.db-journal

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.yarn/
.pnpm-store/

