**/.env.local
**/.env.*.local

# JWT keys / certs / credentials
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
private.key
public.key
secrets/
credentials.json
service-account.json
gcloud-key.json
aws-credentials
.aws/

# ─────────────────────────────────────────────────────────────────────────────
