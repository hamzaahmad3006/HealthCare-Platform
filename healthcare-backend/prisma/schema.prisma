generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VerifStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum VisitStatus {
  SCHEDULED
  ASSIGNED
  EN_ROUTE
  CHECKED_IN
  COMPLETED
  MISSED
  CANCELLED
}

enum PackageType {
  PER_VISIT
  WEEKLY
  MONTHLY
}

enum AssignStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  REASSIGNED
  COMPLETED
  CANCELLED
}

enum ReportType {
  LAB_RESULT
  PRESCRIPTION
  VISIT_NOTE
  PROGRESS_IMAGE
  OTHER
}

enum NotifChannel {
  WHATSAPP
}

enum NotifStatus {
  PENDING
  SENT
  FAILED
}

enum FileProvider {
  S3
  CLOUDINARY
}

enum UrgencyLevel {
  NORMAL
  URGENT
  EMERGENCY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BookingSource {
  WEB
  MOBILE
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// ── City & Zone ───────────────────────────────────────────────────────────────

model City {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  zones     Zone[]
  addresses Address[]
  staff     StaffProfile[]
  packages  Package[]
  bookings  Booking[]

  @@map("cities")
}

model Zone {
  id        String   @id @default(uuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(120)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  addresses Address[]
  staff     StaffProfile[]

  @@unique([cityId, slug])
  @@index([cityId])
  @@map("zones")
}

// ── User & Auth ───────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  role          Role
  fullName      String     @db.VarChar(150)
  email         String?    @unique @db.VarChar(255)
  phone         String     @unique @db.VarChar(20)
  passwordHash  String     @db.VarChar(255)
  // Secure URL of the user's profile picture, hosted on Cloudinary (or
  // whichever storage the cloudinary.helper resolves to). Kept on User
  // rather than role-specific profiles so customers/admins can also have
  // avatars without schema churn.
  avatarUrl     String?    @db.VarChar(1000)
  status        UserStatus @default(ACTIVE)
  phoneVerified Boolean    @default(false)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  refreshTokens   RefreshToken[]
  customerProfile CustomerProfile?
  staffProfile    StaffProfile?
  patients        Patient[]
  addresses       Address[]
  bookings        Booking[]        @relation("CustomerBookings")
  auditLogs       AuditLog[]
  verifiedStaff   StaffProfile[]   @relation("StaffVerifier")

  @@index([role, status])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ── Customer & Patient ────────────────────────────────────────────────────────

model CustomerProfile {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id])
  whatsappNumber    String?  @db.VarChar(20)
  alternatePhone    String?  @db.VarChar(20)
  preferredLanguage String   @default("en") @db.VarChar(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("customer_profiles")
}

model Patient {
  id                     String    @id @default(uuid())
  customerUserId         String
  customer               User      @relation(fields: [customerUserId], references: [id])
  defaultAddressId       String?
  defaultAddress         Address?  @relation("PatientDefaultAddress", fields: [defaultAddressId], references: [id])
  fullName               String    @db.VarChar(150)
  gender                 Gender?
  dateOfBirth            DateTime? @db.Date
  relationshipToCustomer String?   @db.VarChar(50)
  primaryCondition       String?
  allergies              String?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  bookings Booking[]
  reports  Report[]

  @@index([customerUserId])
  @@map("patients")
}

model Address {
  id             String   @id @default(uuid())
  customerUserId String?
  customer       User?    @relation(fields: [customerUserId], references: [id])
  cityId         String
  city           City     @relation(fields: [cityId], references: [id])
  zoneId         String?
  zone           Zone?    @relation(fields: [zoneId], references: [id])
  label          String?  @db.VarChar(50)
  contactName    String   @db.VarChar(150)
  contactPhone   String   @db.VarChar(20)
  line1          String   @db.VarChar(255)
  line2          String?  @db.VarChar(255)
  area           String   @db.VarChar(120)
  postalCode     String?  @db.VarChar(20)
  latitude       Decimal? @db.Decimal(9, 6)
  longitude      Decimal? @db.Decimal(9, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings        Booking[]
  patientDefault  Patient[] @relation("PatientDefaultAddress")

  @@index([customerUserId])
  @@index([cityId, zoneId])
  @@map("addresses")
}

// ── Staff ─────────────────────────────────────────────────────────────────────

model StaffProfile {
  userId             String      @id
  user               User        @relation(fields: [userId], references: [id])
  staffCode          String      @unique @db.VarChar(30)
  // Self-onboarding flow: admin only collects name/phone/email at invite
  // time. cityId and cnic become required once the staff completes their
  // own profile via /complete-profile. profileCompletedAt is the gate the
  // verification flow checks before allowing admin to mark VERIFIED.
  cityId             String?
  city               City?       @relation(fields: [cityId], references: [id])
  zoneId             String?
  zone               Zone?       @relation(fields: [zoneId], references: [id])
  gender             Gender?
  cnic               String?     @unique @db.VarChar(25)
  dateOfBirth        DateTime?   @db.Date
  experienceYears    Int         @default(0)
  profileCompletedAt DateTime?
  verificationStatus VerifStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedByUserId   String?
  verifiedBy         User?       @relation("StaffVerifier", fields: [verifiedByUserId], references: [id])
  idCardNumber       String?     @unique @db.VarChar(50)
  idCardIssuedAt     DateTime?
  uniformIssued      Boolean     @default(false)
  uniformIssuedAt    DateTime?
  // Required only when AMBULANCE is one of the staff's serviceTypes —
  // enforced at the API layer (see staff.controller.completeMyProfile).
  // Kept nullable in the schema so non-ambulance staff don't need it.
  ambulanceNumber    String?     @db.VarChar(20)
  isAvailable        Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  serviceTypes StaffServiceType[]
  documents    StaffDocument[]
  assignments  BookingAssignment[]
  visits       BookingVisit[]      @relation("AssignedStaff")

  @@index([cityId, zoneId])
  @@index([verificationStatus, isAvailable])
  @@map("staff_profiles")
}

model StaffServiceType {
  staffUserId   String
  staff         StaffProfile @relation(fields: [staffUserId], references: [userId])
  serviceTypeId String
  serviceType   ServiceType  @relation(fields: [serviceTypeId], references: [id])
  createdAt     DateTime     @default(now())

  @@id([staffUserId, serviceTypeId])
  @@index([serviceTypeId])
  @@map("staff_service_types")
}

model StaffDocument {
  id                 String       @id @default(uuid())
  staffUserId        String
  staff              StaffProfile @relation(fields: [staffUserId], references: [userId])
  documentType       String       @db.VarChar(50)
  fileProvider       FileProvider
  fileKey            String       @db.VarChar(500)
  fileUrl            String       @db.VarChar(1000)
  mimeType           String       @db.VarChar(100)
  fileSizeBytes      BigInt
  verificationStatus VerifStatus  @default(PENDING)
  uploadedAt         DateTime     @default(now())
  verifiedAt         DateTime?
  verifiedByUserId   String?

  @@index([staffUserId])
  @@map("staff_documents")
}

// ── Service Catalog & Packages ────────────────────────────────────────────────

model ServiceType {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packages   Package[]
  bookings   Booking[]
  staffTypes StaffServiceType[]

  @@map("service_types")
}

model Package {
  id            String      @id @default(uuid())
  cityId        String?
  city          City?       @relation(fields: [cityId], references: [id])
  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id])
  name          String      @db.VarChar(120)
  packageType   PackageType
  durationDays  Int
  visitCount    Int
  priceAmount   Decimal     @db.Decimal(12, 2)
  currency      String      @default("PKR") @db.Char(3)
  description   String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings Booking[]

  @@index([serviceTypeId, packageType, isActive])
  @@index([cityId])
  @@map("packages")
}

// ── Booking & Visits ──────────────────────────────────────────────────────────

model Booking {
  id                   String        @id @default(uuid())
  bookingNumber        String        @unique @db.VarChar(30)
  customerUserId       String
  customer             User          @relation("CustomerBookings", fields: [customerUserId], references: [id])
  patientId            String
  patient              Patient       @relation(fields: [patientId], references: [id])
  serviceTypeId        String
  serviceType          ServiceType   @relation(fields: [serviceTypeId], references: [id])
  packageId            String
  package              Package       @relation(fields: [packageId], references: [id])
  addressId            String
  address              Address       @relation(fields: [addressId], references: [id])
  cityId               String
  city                 City          @relation(fields: [cityId], references: [id])
  preferredStaffGender Gender?
  urgencyLevel         UrgencyLevel  @default(NORMAL)
  requestedStartAt     DateTime
  specialInstructions  String?
  status               BookingStatus @default(PENDING)
  totalPrice           Decimal       @db.Decimal(12, 2)
  currency             String        @default("PKR") @db.Char(3)
  source               BookingSource @default(WEB)
  confirmedAt          DateTime?
  confirmedByUserId    String?
  cancelledAt          DateTime?
  cancelledByUserId    String?
  cancellationReason   String?
  createdByUserId      String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  visits        BookingVisit[]
  assignments   BookingAssignment[]
  reports       Report[]
  reviews       Review[]
  notifications NotificationLog[]
  payments      Payment[]

  @@index([customerUserId, status])
  @@index([patientId])
  @@index([serviceTypeId, status])
  @@index([cityId, status])
  @@index([requestedStartAt])
  @@map("bookings")
}

model BookingVisit {
  id                     String       @id @default(uuid())
  bookingId              String
  booking                Booking      @relation(fields: [bookingId], references: [id])
  sequenceNo             Int
  scheduledStartAt       DateTime
  scheduledEndAt         DateTime?
  assignedStaffUserId    String?
  assignedStaff          StaffProfile? @relation("AssignedStaff", fields: [assignedStaffUserId], references: [userId])
  status                 VisitStatus  @default(SCHEDULED)
  checkInAt              DateTime?
  checkOutAt             DateTime?
  checkInLatitude        Decimal?     @db.Decimal(9, 6)
  checkInLongitude       Decimal?     @db.Decimal(9, 6)
  checkOutLatitude       Decimal?     @db.Decimal(9, 6)
  checkOutLongitude      Decimal?     @db.Decimal(9, 6)
  beforeConditionText    String?
  afterConditionText     String?
  visitNotes             String?
  completedByStaffUserId String?
  cancellationReason     String?
  offlineSyncId          String?      @unique
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  assignments   BookingAssignment[]
  reports       Report[]
  reviews       Review[]
  notifications NotificationLog[]

  @@unique([bookingId, sequenceNo])
  @@index([assignedStaffUserId, status])
  @@index([scheduledStartAt, status])
  @@index([bookingId])
  @@map("booking_visits")
}

model BookingAssignment {
  id               String        @id @default(uuid())
  bookingId        String
  booking          Booking       @relation(fields: [bookingId], references: [id])
  bookingVisitId   String?
  bookingVisit     BookingVisit? @relation(fields: [bookingVisitId], references: [id])
  staffUserId      String
  staff            StaffProfile  @relation(fields: [staffUserId], references: [userId])
  assignedByUserId String
  status           AssignStatus  @default(ASSIGNED)
  responseNote     String?
  assignedAt       DateTime      @default(now())
  respondedAt      DateTime?

  @@index([bookingId])
  @@index([staffUserId, status])
  @@map("booking_assignments")
}

// ── Reports ───────────────────────────────────────────────────────────────────

model Report {
  id                  String        @id @default(uuid())
  bookingId           String
  booking             Booking       @relation(fields: [bookingId], references: [id])
  bookingVisitId      String?
  bookingVisit        BookingVisit? @relation(fields: [bookingVisitId], references: [id])
  patientId           String
  patient             Patient       @relation(fields: [patientId], references: [id])
  uploadedByUserId    String
  reportType          ReportType
  title               String        @db.VarChar(150)
  notes               String?
  isVisibleToCustomer Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  files ReportFile[]

  @@index([patientId, createdAt])
  @@index([bookingId])
  @@map("reports")
}

model ReportFile {
  id             String       @id @default(uuid())
  reportId       String
  report         Report       @relation(fields: [reportId], references: [id])
  fileProvider   FileProvider
  fileKey        String       @db.VarChar(500)
  fileUrl        String       @db.VarChar(1000)
  mimeType       String       @db.VarChar(100)
  fileSizeBytes  BigInt
  checksumSha256 String?      @db.VarChar(64)
  uploadedAt     DateTime     @default(now())

  @@index([reportId])
  @@map("report_files")
}

// ── Reviews ───────────────────────────────────────────────────────────────────

model Review {
  id             String        @id @default(uuid())
  bookingId      String
  booking        Booking       @relation(fields: [bookingId], references: [id])
  bookingVisitId String?
  bookingVisit   BookingVisit? @relation(fields: [bookingVisitId], references: [id])
  customerUserId String
  staffUserId    String?
  rating         Int
  reviewText     String?
  isLowRating    Boolean       @default(false)
  adminFollowedUp Boolean      @default(false)
  createdAt      DateTime      @default(now())

  @@index([bookingId])
  @@index([staffUserId, rating])
  @@map("reviews")
}

// ── Notifications ─────────────────────────────────────────────────────────────

model NotificationLog {
  id                String        @id @default(uuid())
  userId            String?
  bookingId         String?
  booking           Booking?      @relation(fields: [bookingId], references: [id])
  bookingVisitId    String?
  bookingVisit      BookingVisit? @relation(fields: [bookingVisitId], references: [id])
  channel           NotifChannel  @default(WHATSAPP)
  templateCode      String        @db.VarChar(50)
  recipient         String        @db.VarChar(20)
  renderedContent   String
  externalMessageId String?       @db.VarChar(100)
  status            NotifStatus   @default(PENDING)
  providerError     String?
  retryCount        Int           @default(0)
  sentAt            DateTime?
  createdAt         DateTime      @default(now())

  @@index([status, createdAt])
  @@index([bookingId])
  @@map("notification_logs")
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  entityType  String   @db.VarChar(50)
  entityId    String
  action      String   @db.VarChar(50)
  payload     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Payments (Phase 2) ────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(uuid())
  bookingId             String
  booking               Booking       @relation(fields: [bookingId], references: [id])
  stripePaymentIntentId String?       @unique
  stripeIdempotencyKey  String        @unique
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("PKR") @db.Char(3)
  status                PaymentStatus @default(PENDING)
  paidAt                DateTime?
  refundedAt            DateTime?
  refundReason          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([bookingId])
  @@map("payments")
}
